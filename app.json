{
  "expo": {
    "name": "ChronoTask",
    "slug": "chronotask",
    "version": "1.0.0-beta.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "routineapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.SEUNOME.chronotask",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#171F38"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#171F38",
          "imageWidth": 200
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "color": "#3B82F6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f70d87d-eaf8-4fd9-8c3a-d2e22b222b29"
      }
    },
    "owner": "silvajv_7"
  }
}
